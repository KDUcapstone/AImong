<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_home_card"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_quest_emoji"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_path_pill"
        android:gravity="center"
        android:text="🎒"
        android:textColor="@color/text_white"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_action_container"
        app:layout_constraintStart_toEndOf="@+id/tv_quest_emoji"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_quest_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="퀘스트"
            android:textColor="@color/text_white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_quest_reward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="+50 EXP"
            android:textColor="@color/text_sub_grey"
            android:textSize="12sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/btn_action_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_start_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_primary"
            android:paddingHorizontal="24dp"
            android:paddingVertical="10dp"
            android:text="시작"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>