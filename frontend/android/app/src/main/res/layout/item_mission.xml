<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_mission"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#1A2B52"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#243B70"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_stage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_stage_badge"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="1단계" />

        <TextView
            android:id="@+id/tv_review_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_stage_badge"
            android:backgroundTint="#FFD600"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="@string/mission_badge_review"
            android:textColor="#0A1633"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/tv_stage"
            app:layout_constraintStart_toEndOf="@id/tv_stage"
            app:layout_constraintTop_toTopOf="@id/tv_stage"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/iv_status"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_stage"
            tools:text="AI가 뭐예요?" />

        <TextView
            android:id="@+id/tv_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#8A96AD"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@+id/iv_status"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            tools:text="AI의 개념과 할루시네이션을 배워요" />

        <ImageView
            android:id="@+id/iv_status"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_circle_icon_container"
            android:padding="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/ic_check_circle"
            tools:tint="#00FFB2" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 잠금 오버레이: 카드 전체를 덮도록 ConstraintLayout 외부(CardView 자식)로 배치 -->
    <View
        android:id="@+id/view_lock_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B30A1633"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/iv_lock"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_lock"
        android:visibility="gone"
        app:tint="#8A96AD" />

</com.google.android.material.card.MaterialCardView>
