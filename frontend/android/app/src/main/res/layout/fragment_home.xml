<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:fitsSystemWindows="true"
    tools:context=".feature.home.presentation.HomeFragment">

    <!-- 상단 4칩: 하트 · XP · 티켓 · 스트릭 (API topStatus) -->
    <HorizontalScrollView
        android:id="@+id/scroll_top_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_chip_heart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_home_status_chip"
                android:gravity="center"
                android:minHeight="36dp"
                android:textColor="@color/text_white"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="❤️ 5" />

            <TextView
                android:id="@+id/tv_chip_xp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_home_status_chip"
                android:gravity="center"
                android:minHeight="36dp"
                android:textColor="@color/point_purple"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="⚡ 240" />

            <TextView
                android:id="@+id/tv_chip_ticket"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_home_status_chip"
                android:gravity="center"
                android:minHeight="36dp"
                android:textColor="@color/point_gold"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="🎟 3" />

            <TextView
                android:id="@+id/tv_chip_streak"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_home_status_chip"
                android:gravity="center"
                android:minHeight="36dp"
                android:textColor="@color/point_orange"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="🔥 5일" />
        </LinearLayout>
    </HorizontalScrollView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/scroll_top_chips">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <TextView
                android:id="@+id/tv_home_brand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:letterSpacing="0.05"
                android:paddingTop="4dp"
                android:text="@string/home_brand"
                android:textColor="@color/text_sub_grey"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_home_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="4dp"
                android:text="@string/home_title_explore"
                android:textColor="@color/text_white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_home_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="6dp"
                android:textColor="@color/text_sub_grey"
                android:textSize="13sp"
                tools:text="Lv.7 AI 탐험가" />

            <TextView
                android:id="@+id/tv_pet_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textColor="@color/text_sub_grey"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="오늘도 같이 공부해요!"
                tools:visibility="visible" />

            <!-- 학습 경로: 중앙 세로 라인 + 노드 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:minHeight="120dp"
                android:paddingBottom="8dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_horizontal"
                    android:background="@color/quiz_mint" />

                <LinearLayout
                    android:id="@+id/layout_mission_path"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </FrameLayout>

            <!-- 펫 EXP (장착 펫 기준) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_home_card"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✨ 경험치"
                        android:textColor="@color/text_sub_grey"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tv_pet_xp_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="0 / 500 EXP"
                        android:textColor="@color/text_sub_grey"
                        android:textSize="12sp" />
                </RelativeLayout>

                <ProgressBar
                    android:id="@+id/pb_xp"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:progressDrawable="@drawable/progress_xp_gradient" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="28dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅 오늘의 퀘스트"
                        android:textColor="@color/text_white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_quest_progress_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:background="@drawable/bg_home_card"
                        android:backgroundTint="#243B70"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="0/0 완료"
                        android:textColor="#90CAF9"
                        android:textSize="12sp" />
                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/layout_quest_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_gacha_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_gacha_card"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_gacha_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎰 가챠 티켓 0장 보유!"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_gacha_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/home_gacha_until_loaded"
                    android:textColor="#827717"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="@+id/tv_gacha_title"
                    app:layout_constraintTop_toBottomOf="@+id/tv_gacha_title" />

                <TextView
                    android:id="@+id/btn_gacha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_button_gacha_gradient"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="10dp"
                    android:text="뽑기  ➜"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
