<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient"
    android:fitsSystemWindows="true"
    tools:context=".feature.home.presentation.HomeFragment">

    <!-- 1. 가운데 경로 스크롤 (가장 뒤에 렌더링되도록 XML 최상단에 배치) -->
    <!-- 스테이지 스크롤 영역은 상단 칩 아래부터 시작하여 화면 끝까지 차지함 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_path"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:overScrollMode="never"
        android:paddingTop="0dp"
        android:paddingBottom="96dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/frame_click_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="@dimen/home_path_scroll_padding_top"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/container_mission_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="420dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:id="@+id/layout_mission_path"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:orientation="vertical" />
                    
                <!-- Floating Tooltip -->
                <LinearLayout
                    android:id="@+id/layout_floating_tooltip"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tooltip_bubble"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="8dp">

                    <TextView
                        android:id="@+id/tv_tooltip_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/home_bg"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        tools:text="오늘의 미션"/>

                    <TextView
                        android:id="@+id/tv_tooltip_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/home_bg"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"
                        android:visibility="gone"
                        tools:text="레슨 1/6"
                        tools:visibility="visible"/>

                    <TextView
                        android:id="@+id/btn_tooltip_start"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_home_card"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:gravity="center"
                        android:text="시작"
                        android:textColor="@color/text_white"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 2. 상단 4칩 (경로 위를 덮도록 나중에 선언) -->
    <HorizontalScrollView
        android:id="@+id/scroll_top_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="12dp"
        android:fillViewport="true"
        android:paddingHorizontal="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="0dp"
        android:scrollbars="none"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_chip_heart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_home_status_chip"
                android:gravity="center"
                android:minHeight="36dp"
                android:textColor="@color/text_white"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="❤️ 5" />

            <TextView
                android:id="@+id/tv_chip_xp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_home_status_chip"
                android:gravity="center"
                android:minHeight="36dp"
                android:textColor="@color/point_purple"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="⚡ 240" />

            <TextView
                android:id="@+id/tv_chip_ticket"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_home_status_chip"
                android:gravity="center"
                android:minHeight="36dp"
                android:textColor="@color/point_gold"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="🎟 3" />

            <TextView
                android:id="@+id/tv_chip_streak"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_home_status_chip"
                android:gravity="center"
                android:minHeight="36dp"
                android:textColor="@color/point_orange"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="🔥 5일" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- 섹션 카드 + 퀘스트: 칩 아래에 고정(플로팅), 스크롤과 분리 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:background="@android:color/transparent"
        android:elevation="10dp"
        android:paddingHorizontal="4dp"
        android:paddingBottom="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scroll_top_chips">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_section_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:layout_constraintEnd_toStartOf="@id/btn_mini_quest"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_home_section_banner_gradient"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_home_brand"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#E5F9D6"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="섹션 1" />

                    <TextView
                        android:id="@+id/tv_home_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="AI가 뭐예요?" />
                </LinearLayout>

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_nav_study_color"
                    app:tint="@color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/btn_mini_quest"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_path_pill"
            android:clickable="true"
            android:elevation="6dp"
            android:focusable="true"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝"
                android:textColor="@color/text_white"
                android:textSize="26sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
