<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_child_stub"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.kduniv.aimong.feature.dev.mock.MockHomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_learningFragment"
            app:destination="@id/learningFragment" />
        <action
            android:id="@+id/action_homeFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
        <action
            android:id="@+id/action_homeFragment_to_gachaFragment"
            app:destination="@id/gachaFragment" />
        <action
            android:id="@+id/action_homeFragment_to_quizFragment"
            app:destination="@id/quizFragment" />
    </fragment>

    <fragment
        android:id="@+id/learningFragment"
        android:name="com.kduniv.aimong.feature.dev.mock.MockMissionListFragment"
        android:label="Missions"
        tools:layout="@layout/fragment_mission_list">
        <action
            android:id="@+id/action_learningFragment_to_quizFragment"
            app:destination="@id/quizFragment" />
        <action
            android:id="@+id/action_learningFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.kduniv.aimong.feature.chat.ChatFragment"
        android:label="Chat"
        tools:layout="@layout/fragment_chat" />

    <fragment
        android:id="@+id/quizFragment"
        android:name="com.kduniv.aimong.feature.dev.mock.DummyQuizFragment"
        android:label="Quiz"
        tools:layout="@layout/fragment_quiz">
        <argument
            android:name="missionId"
            android:defaultValue="stub-mission"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/gachaFragment"
        android:name="com.kduniv.aimong.feature.gacha.GachaFragment"
        android:label="Gacha"
        tools:layout="@layout/fragment_gacha" />

</navigation>
