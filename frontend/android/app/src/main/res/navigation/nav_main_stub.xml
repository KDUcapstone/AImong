<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_main_stub"
    app:startDestination="@id/roleSelectFragment">

    <fragment
        android:id="@+id/roleSelectFragment"
        android:name="com.kduniv.aimong.feature.dev.mock.MockRoleSelectFragment"
        android:label="Role Selection"
        tools:layout="@layout/fragment_role_select">
        <action
            android:id="@+id/action_roleSelectFragment_to_parentLoginFragment"
            app:destination="@id/parentLoginFragment" />
        <action
            android:id="@+id/action_roleSelectFragment_to_childCodeFragment"
            app:destination="@id/childCodeFragment" />
    </fragment>

    <fragment
        android:id="@+id/parentLoginFragment"
        android:name="com.kduniv.aimong.feature.dev.mock.MockParentLoginFragment"
        android:label="Parent Login"
        tools:layout="@layout/fragment_parent_login">
        <action
            android:id="@+id/action_parentLoginFragment_to_parentOnboardingFragment"
            app:destination="@id/parentOnboardingFragment" />
    </fragment>

    <fragment
        android:id="@+id/parentOnboardingFragment"
        android:name="com.kduniv.aimong.feature.auth.presentation.ParentOnboardingFragment"
        android:label="Parent Onboarding"
        tools:layout="@layout/fragment_parent_onboarding">
        <action
            android:id="@+id/action_parentOnboardingFragment_to_parentRegisterChildFragment"
            app:destination="@id/parentRegisterChildFragment" />
    </fragment>

    <fragment
        android:id="@+id/parentRegisterChildFragment"
        android:name="com.kduniv.aimong.feature.dev.mock.MockParentRegisterChildFragment"
        android:label="Parent Register Child"
        tools:layout="@layout/fragment_parent_register_child" />

    <fragment
        android:id="@+id/childCodeFragment"
        android:name="com.kduniv.aimong.feature.dev.mock.MockChildCodeFragment"
        android:label="Child Login"
        tools:layout="@layout/fragment_child_code" />

</navigation>
