<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 3D 그림자 (하단) -->
    <item android:top="6dp">
        <shape android:shape="oval">
            <solid android:color="#5E35B1" />
        </shape>
    </item>

    <!-- 메인 표면 (그라데이션) -->
    <item android:bottom="8dp">
        <shape android:shape="oval">
            <gradient
                android:angle="90"
                android:startColor="@color/point_purple"
                android:endColor="@color/point_pink"
                android:type="linear" />
        </shape>
    </item>

    <!-- 상단 하이라이트 (입체감을 위한 빛 반사 효과) -->
    <item android:bottom="8dp" android:insetTop="6dp" android:insetLeft="16dp" android:insetRight="16dp" android:insetBottom="50dp">
        <shape android:shape="oval">
            <solid android:color="#40FFFFFF" />
        </shape>
    </item>
</layer-list>
