<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 기본 배경 및 파란색 테두리 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A2B52" />
            <corners android:radius="20dp" />
            <stroke android:width="2.5dp" android:color="#3A86FF" />
        </shape>
    </item>
    <!-- 유리 느낌의 상단 하이라이트 (Glassmorphism Lite) -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="#26FFFFFF" /> <!-- 15% 투명도 흰색 -->
        </shape>
    </item>
</layer-list>
