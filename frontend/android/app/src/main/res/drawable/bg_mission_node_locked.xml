<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 3D 그림자 (하단) -->
    <item android:top="4dp">
        <shape android:shape="oval">
            <solid android:color="#1F2336" />
        </shape>
    </item>

    <!-- 메인 표면 (그라데이션) -->
    <item android:bottom="6dp">
        <shape android:shape="oval">
            <gradient
                android:angle="90"
                android:startColor="#2C314A"
                android:endColor="#4A4F6C"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
