<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:fitsSystemWindows="true"
    tools:context=".feature.home.presentation.HomeFragment">

    <!-- 상단 상태바 영역 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 스트릭 배지 -->
        <TextView
            android:id="@+id/tv_streak_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_streak"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="🔥 7일 연속!"
            android:textColor="#FF6D00"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 레벨/칭호 배지 -->
        <TextView
            android:id="@+id/tv_level_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_home_level"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="🔍 Lv.7 AI탐험가"
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_streak_badge"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 에너지(번개) 영역 -->
        <LinearLayout
            android:id="@+id/layout_energy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/point_gold" />
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/point_gold" />
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/point_gold" />
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:src="@android:drawable/ic_menu_send"
                app:tint="#424242" />
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/ic_lock_power_off"
                app:tint="@color/point_gold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_top_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- 펫 말풍선 -->
            <TextView
                android:id="@+id/tv_pet_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_speech_bubble"
                android:backgroundTint="#263238"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="오늘도 같이 공부해요! 😊"
                android:textColor="@color/text_white"
                android:textSize="13sp" />

            <!-- 캐릭터 영역 -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">
                <View
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:background="@android:drawable/presence_online"
                    android:backgroundTint="#26A69A" />
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/lottie_pet"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/pet_idle" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_pet_name_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="팩트봇 Lv.3"
                android:textColor="#A5D6A7"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- EXP 바 영역 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✨ 경험치"
                        android:textColor="@color/text_sub_grey"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tv_pet_xp_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="340 / 500 EXP"
                        android:textColor="@color/text_sub_grey"
                        android:textSize="12sp" />
                </RelativeLayout>

                <ProgressBar
                    android:id="@+id/pb_xp"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:progress="68"
                    android:progressDrawable="@drawable/progress_xp_gradient" />
            </LinearLayout>

            <!-- 오늘의 퀘스트 섹션 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="32dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅 오늘의 퀘스트"
                        android:textColor="@color/text_white"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_quest_progress_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:background="@drawable/bg_home_card"
                        android:backgroundTint="#243B70"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="2/3 완료"
                        android:textColor="#90CAF9"
                        android:textSize="12sp" />
                </RelativeLayout>

                <!-- 퀘스트 리스트 (수동 추가 또는 RecyclerView) -->
                <LinearLayout
                    android:id="@+id/layout_quest_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- 가챠 뽑기 배너 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_gacha_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_home_card"
                android:backgroundTint="#1A1A1A"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_gacha_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/point_gold" />

                <TextView
                    android:id="@+id/tv_gacha_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="가챠 티켓 3장 보유!"
                    android:textColor="@color/point_gold"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_gacha_icon"
                    app:layout_constraintStart_toEndOf="@+id/iv_gacha_icon"
                    app:layout_constraintTop_toTopOf="@+id/iv_gacha_icon" />

                <TextView
                    android:id="@+id/tv_gacha_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="레전드 확률 4% (Lv.7)"
                    android:textColor="#827717"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="@+id/tv_gacha_title"
                    app:layout_constraintTop_toBottomOf="@+id/tv_gacha_title" />

                <TextView
                    android:id="@+id/btn_gacha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_home_streak"
                    android:backgroundTint="@color/point_gold"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"
                    android:text="뽑기 →"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 하단 탭바 (이미지 시안용 더미) -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#050C1F"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">
        <!-- 실제 앱에서는 BottomNavigationView 사용 -->
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
