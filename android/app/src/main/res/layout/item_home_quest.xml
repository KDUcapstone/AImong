<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_quest_item"
    android:padding="16dp">

    <ImageView
        android:id="@+id/iv_quest_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_home_energy"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_help"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#90CAF9" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_action"
        app:layout_constraintStart_toEndOf="@+id/iv_quest_icon"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_quest_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI 퀴즈 3문제 맞히기"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_quest_reward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="+50 EXP · 가챠 티켓 1장"
            android:textColor="@color/text_sub_grey"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 체크표시 이미지 또는 시작 버튼 -->
    <FrameLayout
        android:id="@+id/btn_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_completed"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/checkbox_on_background"
            android:visibility="gone"
            app:tint="@color/point_green" />

        <TextView
            android:id="@+id/tv_start_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_level"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:text="▶ 시작"
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
