<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1633"
    android:fitsSystemWindows="true">

    <!-- 상단 바 -->
    <ImageView
        android:id="@+id/iv_back"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_margin="20dp"
        android:src="@drawable/ic_back_white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧠 AI 퀴즈"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/iv_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_back" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_review_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="#FFD600"
        app:cardCornerRadius="4dp"
        app:layout_constraintBottom_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toEndOf="@id/tv_title"
        app:layout_constraintTop_toTopOf="@id/tv_title">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="4dp"
            android:paddingVertical="1dp"
            android:text="복습"
            android:textColor="#0A1633"
            android:textSize="10sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layout_hearts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@id/iv_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_back">

        <ImageView
            android:id="@+id/iv_heart1"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_heart_filled" />
        <ImageView
            android:id="@+id/iv_heart2"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_heart_filled" />
        <ImageView
            android:id="@+id/iv_heart3"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_heart_filled" />
    </LinearLayout>

    <!-- 진행도 및 정보 -->
    <TextView
        android:id="@+id/tv_question_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:text="1 / 10 문제"
        android:textColor="#8A96AD"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <TextView
        android:id="@+id/tv_exp_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:text="+50 EXP 완료 시"
        android:textColor="#8A96AD"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="@id/tv_question_count"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/pb_quiz_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:max="10"
        android:progress="1"
        android:progressDrawable="@drawable/progress_xp_gradient"
        app:layout_constraintTop_toBottomOf="@id/tv_question_count" />

    <!-- 문제 카드 영역 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_question_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/pb_quiz_progress">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lav_quiz_pet"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/pet_idle" />

        <ImageView
            android:id="@+id/iv_bubble_tail"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginStart="-1dp"
            android:layout_marginTop="30dp"
            android:src="@drawable/bg_quiz_bubble_tail"
            app:layout_constraintStart_toEndOf="@id/lav_quiz_pet"
            app:layout_constraintTop_toTopOf="@id/card_question" />

        <androidx.cardview.widget.CardView
            android:id="@+id/card_question"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            app:cardBackgroundColor="#1A2B52"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_bubble_tail"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_quiz_question"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:text="문제를 불러오는 중..."
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_timer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ 25초 남음"
                        android:textColor="#8A96AD"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="#408A96AD" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="난이도"
                        android:textColor="#8A96AD"
                        android:textSize="12sp"
                        android:layout_marginEnd="4dp"/>

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_star_filled"
                        android:layout_marginEnd="2dp"/>
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_star_filled" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 선택지 영역 -->
    <FrameLayout
        android:id="@+id/layout_options_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/layout_question_card">

        <!-- 일반 객관식 (동적 생성용) -->
        <LinearLayout
            android:id="@+id/layout_options_standard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

        <!-- OX 전용 유형 -->
        <LinearLayout
            android:id="@+id/layout_options_ox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_ox_o"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/home_card_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#243B70"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_ox_o_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="O"
                        android:textColor="@color/quiz_mint"
                        android:textSize="64sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_ox_o_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="맞아요"
                        android:textColor="@color/quiz_mint"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_ox_x"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/home_card_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#243B70"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_ox_x_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="X"
                        android:textColor="@color/quiz_red"
                        android:textSize="64sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_ox_x_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="아니에요"
                        android:textColor="@color/quiz_red"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- 단어/상황 전용 (ChipGroup - Wrapping) -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/layout_options_chips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:chipSpacingHorizontal="12dp"
            app:chipSpacingVertical="12dp"
            app:singleLine="false"
            app:singleSelection="true"/>

    </FrameLayout>

    <!-- 힌트 버튼 -->
    <LinearLayout
        android:id="@+id/layout_hint_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_hint_button"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_options_container">
        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡 힌트 보기"
            android:textColor="#FFD600"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 피드백 패널 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/layout_feedback_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardBackgroundColor="#0D1D41"
        app:cardCornerRadius="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="-20dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="52dp">
            <TextView
                android:id="@+id/tv_feedback_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#00FFB2"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_feedback_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"
                android:textColor="#C0C8D8"
                android:textSize="14sp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_feedback_retry"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:backgroundTint="#1A2B52"
                    android:text="다시보기"
                    android:textAllCaps="false"
                    android:textColor="#8A96AD"
                    app:cornerRadius="16dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_next_question"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="12dp"
                    android:layout_weight="2"
                    android:backgroundTint="#00FFB2"
                    android:text="다음 문제 →"
                    android:textAllCaps="false"
                    android:textColor="#0A1633"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 결과 오버레이 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_quiz_result"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/lav_feedback"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true" />

                <LinearLayout
                    android:id="@+id/layout_result_hearts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">
                    <ImageView
                        android:id="@+id/iv_result_heart1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_margin="4dp"
                        android:src="@drawable/ic_heart_filled" />
                    <ImageView
                        android:id="@+id/iv_result_heart2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_margin="4dp"
                        android:src="@drawable/ic_heart_filled" />
                    <ImageView
                        android:id="@+id/iv_result_heart3"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_margin="4dp"
                        android:src="@drawable/ic_heart_filled" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_result_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#00FFB2"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="미션 성공!" />
                <TextView
                    android:id="@+id/tv_result_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textSize="18sp"
                    tools:text="10문제 중 8문제 정답" />
                <TextView
                    android:id="@+id/tv_result_xp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#00FFB2"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="+50 EXP 획득 (+10 보너스)" />

                <LinearLayout
                    android:id="@+id/layout_rewards_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:orientation="horizontal" />

                <TextView
                    android:id="@+id/tv_streak_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#FFD600"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="🔥 7일 연속 스트릭 유지 중!" />

                <TextView
                    android:id="@+id/tv_wrong_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#8A96AD"
                    android:textSize="14sp"
                    tools:text="틀린 문제: 2개" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_view_solutions"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:backgroundTint="#1A2B52"
                        android:text="풀이 보기"
                        android:textColor="#00FFB2"
                        android:textStyle="bold"
                        app:cornerRadius="16dp"
                        app:strokeColor="#00FFB2"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_retry_quiz"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="#00FFB2"
                        android:text="복습하기"
                        android:textColor="#0A1633"
                        android:textStyle="bold"
                        app:cornerRadius="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_finish"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="?android:attr/colorBackgroundFloating"
                        android:text="홈으로"
                        android:textColor="#8A96AD"
                        app:cornerRadius="16dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
