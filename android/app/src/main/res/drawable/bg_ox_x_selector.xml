<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected state -->
    <item android:state_selected="true">
        <shape>
            <solid android:color="#1A2B52" />
            <corners android:radius="24dp" />
            <stroke android:width="3dp" android:color="#FF4B4B" />
        </shape>
    </item>
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#243B70" />
            <corners android:radius="24dp" />
            <stroke android:width="2dp" android:color="#FF4B4B" />
        </shape>
    </item>
    <!-- Default state -->
    <item>
        <shape>
            <solid android:color="#1A2B52" />
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="#243B70" />
        </shape>
    </item>
</selector>