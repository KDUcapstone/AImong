<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 기본 배경 및 금색 테두리 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2D2400" />
            <corners android:radius="16dp" />
            <stroke android:width="2dp" android:color="#FFD700" />
        </shape>
    </item>
    <!-- 상단 유리 효과 하이라이트 -->
    <item android:top="0.5dp" android:left="0.5dp" android:right="0.5dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <stroke android:width="1.2dp" android:color="#33FFFFFF" /> <!-- 20% 투명도 흰색 -->
        </shape>
    </item>
</layer-list>
